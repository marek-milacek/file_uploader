<!DOCTYPE html>
<html lang="en">
    <head>
        <%- include("./partials/head") %>
    </head>
    <body class="min-h-screen bg-slate-50 text-slate-900 p-4">
        <main class="mx-auto max-w-4xl rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-3xl font-semibold">Welcome to the Dashboard!</h1>
                    <p class="text-slate-600">Logged in as <span class="font-medium text-slate-800"><%= user.email %></span></p>
                </div>
                <a href="/logout" class="rounded-full bg-slate-900 px-5 py-3 text-white hover:bg-slate-700">Log out</a>
            </div>
            <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 p-6">
                <p class="text-slate-700">For uploading files, use the button below.</p>
                <a href="/upload" class="mt-4 inline-block rounded-full bg-sky-600 px-5 py-3 text-white hover:bg-sky-500">Upload File</a>
            </div>

            <% if (files && files.length) { %>
                <section class="mt-8">
                    <h2 class="text-2xl font-semibold mb-4">Uploaded files</h2>
                    <ul class="space-y-3">
                        <% files.forEach((file) => { %>
                            <li class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                                    <div>
                                        <p class="font-medium text-slate-900"><%= file.name %></p>
                                        <p class="text-sm text-slate-500">
                                            <span><%= file.size %> bytes</span>
                                            <span class="mx-2">•</span>
                                            <span>Uploaded on <%= new Date(file.createdAt).toLocaleString() %></span>
                                        </p>
                                    </div>
                                    <div class="flex flex-wrap gap-2">
                                        <a href="/upload/download/<%= file.id %>" class="rounded-full border border-slate-300 px-4 py-2 text-slate-800 hover:bg-slate-100">Stáhnout</a>
                                        <a href="/upload/delete/<%= file.id %>" class="rounded-full border border-red-300 bg-red-50 px-4 py-2 text-red-700 hover:bg-red-100">Smazat</a>
                                    </div>
                                </div>
                            </li>
                        <% }); %>
                    </ul>
                </section>
            <% } else { %>
                <p class="mt-6 text-slate-600">Uploaded files will appear here.</p>
            <% } %>
        </main>
    </body>
</html>
