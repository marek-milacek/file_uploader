<!DOCTYPE html>
<html lang="en">
    <head>
        <%- include("./partials/head") %>
    </head>
    <body>
        <h1>Welcome to the Dashboard!</h1>
        <a href="/logout">Log out</a>
        <p>For uploading files, please use the upload link below:</p>
        <a href="/upload">Upload File</a>

        <% if (files && files.length) { %>
            <h2>Uploaded files</h2>
            <ul>
                <% files.forEach((file) => { %>
                    <li>
                        <strong><%= file.name %></strong>
                        (<%= file.size %> bytes)
                        - <a href="/upload/download/<%= file.id %>">Stáhnout</a>
                        - <a href="/upload/delete/<%= file.id %>">Smazat</a>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>Uploaded files will appear here.</p>
        <% } %>
    </body>
</html>
